# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Used for local map builds; never commit real keys.
STADIA_API_KEY=your_stadia_api_key_here
MAPTILER_API_KEY=your_maptiler_key_here

# Optional: a custom MapTiler style id with place labels hidden.
# Leave unset to test plumbing with the built-in "streets-v2" (shows labels).
MAPTILER_STYLE=
